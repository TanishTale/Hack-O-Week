#include <stdio.h>
#include <string.h>
#include <ctype.h>

#define MAX 200
#define WORDS 50

// Stopwords list
char *stopwords[] = {
    "is","the","a","an","and","or","in","on","at","to","for","of","with","by"
};
int stopword_count = 14;

// Convert to lowercase
void toLowerCase(char *str) {
    for(int i = 0; str[i]; i++) {
        str[i] = tolower(str[i]);
    }
}

// Remove punctuation
void removePunctuation(char *str) {
    int i, j = 0;
    char temp[MAX];

    for(i = 0; str[i]; i++) {
        if(isalnum(str[i]) || str[i] == ' ') {
            temp[j++] = str[i];
        }
    }
    temp[j] = '\0';
    strcpy(str, temp);
}

// Check if word is stopword
int isStopword(char *word) {
    for(int i = 0; i < stopword_count; i++) {
        if(strcmp(word, stopwords[i]) == 0) {
            return 1;
        }
    }
    return 0;
}

// Basic spelling normalization (very simple rules)
void normalizeWord(char *word) {
    // example: "plz" -> "please"
    if(strcmp(word, "plz") == 0) strcpy(word, "please");
    if(strcmp(word, "u") == 0) strcpy(word, "you");
    if(strcmp(word, "ur") == 0) strcpy(word, "your");
}

// Tokenization + preprocessing
void preprocess(char *input) {
    char *tokens[WORDS];
    int count = 0;

    // Step 1: lowercase
    toLowerCase(input);

    // Step 2: remove punctuation
    removePunctuation(input);

    // Step 3: tokenize
    char *token = strtok(input, " ");
    while(token != NULL) {
        normalizeWord(token);

        // Step 4: remove stopwords
        if(!isStopword(token)) {
            tokens[count++] = token;
        }

        token = strtok(NULL, " ");
    }

    // Output processed tokens
    printf("\nProcessed Tokens:\n");
    for(int i = 0; i < count; i++) {
        printf("%s ", tokens[i]);
    }
    printf("\n");
}

int main() {
    char input[MAX];

    printf("Enter student question:\n");
    fgets(input, sizeof(input), stdin);

    // remove newline
    input[strcspn(input, "\n")] = 0;

    preprocess(input);

    return 0;
}
